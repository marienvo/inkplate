# Discovery mode (recommended)
SONOS_MASTER_NAME=TV
SONOS_EXCLUDED_SPEAKERS=

# Manual fallback mode (used only when SONOS_MASTER_NAME is not set)
# SONOS_MASTER_IP=192.168.1.100
# SONOS_SPEAKER_IPS=192.168.1.101,192.168.1.102

POLL_INTERVAL_SECONDS=20
LOG_LEVEL=INFO
DRY_RUN=false

# Optional settings
# DISCOVERY_TIMEOUT=5
# LOG_FILE=/home/pi/sonos-grouper.log
