{
  "name": "inkplate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "fetch-weather": "tsx scripts/fetchWeather.ts",
    "prebuild": "npm run fetch-weather",
    "build": "vite build",
    "serve": "tsx server/index.ts",
    "generate": "tsx server/index.ts --once",
    "browser:install": "puppeteer browsers install chrome",
    "upload": "arduino-cli compile --fqbn Inkplate_Boards:esp32:Inkplate5V2 firmware && arduino-cli upload -p ${INKPLATE_PORT:?Set INKPLATE_PORT env var} --fqbn Inkplate_Boards:esp32:Inkplate5V2 firmware",
    "surge": "npm run generate && surge dist/ b93t6z.marienvanoverbeek.nl"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "express": "^5.2.1",
    "lucide-react": "^0.575.0",
    "puppeteer": "^24.37.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
