{
  "name": "inkplate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p scripts/tsconfig.json",
    "fetch-weather": "tsx scripts/fetchWeather.ts",
    "fetch-calendar": "tsx scripts/fetchCalendar.ts",
    "prebuild": "npm run fetch-weather && npm run fetch-calendar && npm run fetch-settings",
    "build": "vite build",
    "serve": "tsx server/index.ts",
    "generate": "tsx server/index.ts --once",
    "upload": "arduino-cli compile --fqbn Inkplate_Boards:esp32:Inkplate5V2 firmware && arduino-cli upload -p ${INKPLATE_PORT:?Set INKPLATE_PORT env var} --fqbn Inkplate_Boards:esp32:Inkplate5V2 firmware",
    "surge": "npm run generate && tsx scripts/deploySurge.ts",
    "r2": "npm run generate && tsx scripts/deployR2.ts",
    "settings": "tsx scripts/deploySettings.ts",
    "fetch-settings": "tsx scripts/fetchSettings.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "express": "^5.2.1",
    "ical.js": "^2.2.1",
    "lucide-react": "^0.575.0",
    "puppeteer-core": "^24.37.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
